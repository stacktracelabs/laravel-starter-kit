{
  "$schema": "https://json.schemastore.org/package.json",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "run-p type-check \"build-only {@}\" --",
    "build-only": "vite build && vite build --ssr",
    "build:ssr": "npm run build",
    "dev": "vite",
    "format": "prettier --write resources/",
    "format:check": "prettier --check resources/",
    "lint": "run-s \"lint:*\"",
    "lint:eslint": "eslint resources/js --fix --cache",
    "lint:oxlint": "oxlint resources/js --fix",
    "type-check": "vue-tsc --build"
  },
  "dependencies": {
    "@inertiajs/vite": "^3.4.0",
    "@inertiajs/vue3": "^3.4.0",
    "@lucide/vue": "^1.21.0",
    "@vueuse/core": "^14.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lodash": "^4.17.21",
    "query-string": "^9.2.2",
    "reka-ui": "^2.10.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.1",
    "tw-animate-css": "^1.4.0",
    "vue": "^3.5.38",
    "ziggy-js": "^2.6.3"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^24.13.2",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/eslint-config-typescript": "^14.9.0",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-oxlint": "~1.71.0",
    "eslint-plugin-vue": "~10.9.2",
    "jiti": "^2.7.0",
    "laravel-vite-plugin": "^3.1.0",
    "npm-run-all2": "^9.0.2",
    "oxlint": "~1.71.0",
    "prettier": "3.8.4",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "typescript": "~6.0.0",
    "vite": "^8.0.16",
    "vite-plugin-vue-devtools": "^8.1.2",
    "vue-eslint-parser": "^10.4.1",
    "vue-tsc": "^3.3.5"
  },
  "engines": {
    "node": "^22.22.2 || ^24.15.0 || >=26.0.0"
  }
}
